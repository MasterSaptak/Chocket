rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // CHOCKET ROLE-BASED ACCESS CONTROL
    // Roles: buyer, seller, manager, super_admin
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticatedBase() {
      return request.auth != null;
    }

    function isAuthenticated() {
      return isAuthenticatedBase() && request.auth.token.email_verified == true;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      return getUserData().role;
    }

    function isRole(role) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserRole() == role;
    }
    
    function isBuyer() {
      return isRole('buyer');
    }
    
    function isSeller() {
      return isRole('seller');
    }
    
    function isManager() {
      return isAuthenticated() &&
        (isRole('manager') || isSuperAdmin());
    }
    
    function isSuperAdmin() {
      return isAuthenticated() &&
        (isRole('primeadmin') ||
          (request.auth.token.email == "BUrningSOUlofDarkness@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isOwner(userId) {
      return isAuthenticatedBase() && request.auth.uid == userId;
    }

    function isUserActive() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().status == 'active';
    }
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isPositiveNumber(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    // ===============================================================
    // USERS COLLECTION
    // ===============================================================
    match /users/{userId} {
      // Users can read their own data; managers & super_admin can read all
      allow read: if isOwner(userId) || isManager();
      
      // Users can create their own profile (on signup)
      allow create: if isOwner(userId) &&
        hasRequiredFields(['uid', 'name', 'email', 'role', 'status', 'createdAt']) &&
        request.resource.data.role == 'buyer' &&
        request.resource.data.status == 'active';
      
      // Users can update their own non-role fields
      // Managers can update sellers/buyers (NOT other managers)
      // Super Admin can update anyone
      allow update: if (
        // User updating own profile (cannot change role or status)
        (isOwner(userId) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status) ||
        // Manager can update buyers and sellers only
        (isManager() && !isSuperAdmin() &&
          resource.data.role in ['buyer', 'seller'] &&
          request.resource.data.role in ['buyer', 'seller']) ||
        // Super Admin can do anything
        isSuperAdmin()
      );
      
      // Only Super Admin can delete users
      allow delete: if isSuperAdmin();
    }

    // ===============================================================
    // SELLER APPLICATIONS COLLECTION
    // ===============================================================
    match /sellerApplications/{applicationId} {
      // Buyers can read their own applications; managers can read all
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isManager()
      );
      
      // Authenticated buyers can create applications
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        hasRequiredFields(['userId', 'fullName', 'email', 'phone', 'location', 'sellingPlatform', 'experience', 'status']);
      
      // Managers can update applications (approve/reject)
      allow update: if isManager();
      
      // No deletion
      allow delete: if false;
    }

    // ===============================================================
    // PRODUCTS COLLECTION (contains ONLY live products)
    // ===============================================================
    match /products/{productId} {
      // Everyone can read live products
      allow read: if true;
      
      // Managers and Super Admin can create products directly
      allow create: if isManager();
      
      // Managers and Super Admin can update products
      allow update: if isManager();
      
      // Managers and Super Admin can delete products
      allow delete: if isManager();
    }

    // ===============================================================
    // PRODUCT VERSIONS COLLECTION (moderation queue)
    // ===============================================================
    match /product_versions/{versionId} {
      // Sellers can read their own versions; managers can read all
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        isManager()
      );
      
      // Sellers can create versions (submit for review)
      allow create: if isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'pending_review' &&
        (isSeller() || isManager());
      
      // Managers can update versions (approve/reject)
      // Super Admin can also bypass
      allow update: if isManager();
      
      // No deletion
      allow delete: if isSuperAdmin();
    }

    // ===============================================================
    // ORDERS COLLECTION
    // ===============================================================
    match /orders/{orderId} {
      // Users can read their own orders; sellers can read orders with their sellerId; managers/super_admin can read all
      allow read: if isManager() || 
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      
      // Authenticated users (buyers) can create orders
      allow create: if isAuthenticated();
      
      // Sellers can update ONLY status field on their own orders (no cancel)
      // Managers and Super Admin can update any order
      allow update: if (
        (isSeller() && resource.data.sellerId == request.auth.uid &&
          request.resource.data.status in ['processing', 'shipped', 'delivered']) ||
        isManager()
      );
      
      // Orders cannot be deleted
      allow delete: if false;
    }

    // ===============================================================
    // PAYOUTS COLLECTION
    // ===============================================================
    match /payouts/{payoutId} {
      // Sellers can read their own payouts; super_admin can read all
      allow read: if isSuperAdmin() ||
        (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      
      // Sellers can create payout requests
      allow create: if isAuthenticated() &&
        isSeller() &&
        request.resource.data.sellerId == request.auth.uid &&
        request.resource.data.status == 'pending';
      
      // Only super_admin can update payouts (approve/process)
      allow update: if isSuperAdmin();
      
      // No deletion
      allow delete: if false;
    }

    // ===============================================================
    // AUDIT LOGS COLLECTION
    // ===============================================================
    match /audit_logs/{logId} {
      // Only managers and super_admin can read audit logs
      allow read: if isManager();
      
      // Any authenticated user can create logs (actions are logged from client)
      allow create: if isAuthenticated();
      
      // Logs are immutable
      allow update: if false;
      allow delete: if false;
    }

    // ===============================================================
    // REVIEWS COLLECTION
    // ===============================================================
    match /reviews/{reviewId} {
      // Anyone can read approved reviews. Managers can read all.
      allow read: if isManager() || (resource.data.status == 'approved');
      
      // Authenticated users can create reviews
      allow create: if isAuthenticated();
      
      // Only managers can update reviews (approve/reject)
      allow update: if isManager();
      
      // Only managers can delete reviews
      allow delete: if isManager();

    // ===============================================================
    // NEWSLETTER COLLECTION
    // ===============================================================
    match /newsletter/{email} {
      allow read: if isManager();
      allow create: if true; // Public can sign up
      allow update, delete: if isManager();
    }

    // ===============================================================
    // FAVORITES / WISHLIST COLLECTION
    // ===============================================================
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

    // ===============================================================
    // BRANDS COLLECTION
    // ===============================================================
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isManager();
    }
  }
}
